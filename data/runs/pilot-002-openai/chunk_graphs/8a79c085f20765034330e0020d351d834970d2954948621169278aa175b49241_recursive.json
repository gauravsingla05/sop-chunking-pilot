{"doc_sha": "8a79c085f20765034330e0020d351d834970d2954948621169278aa175b49241", "chunker": "recursive", "graphs": [{"chunk_idx": 5, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1026, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 12, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1007, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 17, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1009, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 18, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 967, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 27, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1115, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 32, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 903, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 33, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1080, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 36, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1029, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 38, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1032, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 39, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1057, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 45, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1057, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 49, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 893, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 51, "graph": {"steps": [{"id": "s1", "ordinal": 1, "text": "Initiate dialogue through written correspondence announcing a regulatory action that may have Tribal implications.", "page": 31}, {"id": "s2", "ordinal": 2, "text": "Send copies of correspondence relating to NEPA or NHPA actions to the Tribal Historic Preservation Officer (THPO) or equivalent staff.", "page": 31}, {"id": "s3", "ordinal": 3, "text": "Describe the proposed regulatory action and identify the location and methods for the Tribe to provide comments or request additional information.", "page": 31}, {"id": "s4", "ordinal": 4, "text": "Include information on the environmental review and NHPA Section 106 processes and an invitation for participation.", "page": 31}, {"id": "s5", "ordinal": 5, "text": "Conduct a follow-up meeting with Tribal officials or representatives based on expressions of interest from individual Tribes.", "page": 31}], "preconditions": [], "constraints": [], "edges": [{"type": "precedes", "from": "s1", "to": "s2"}, {"type": "precedes", "from": "s2", "to": "s3"}, {"type": "precedes", "from": "s3", "to": "s4"}, {"type": "precedes", "from": "s4", "to": "s5"}]}, "error": null, "input_tokens": 995, "output_tokens": 397, "cached_tokens": null}, {"chunk_idx": 53, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 921, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 61, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1016, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 62, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1026, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 64, "graph": {"steps": [{"id": "s1", "ordinal": 1, "text": "Demonstrate the importance NRC places on government to government relationships with Tribal nations.", "page": 38}, {"id": "s2", "ordinal": 2, "text": "Avoid judgmental attitudes.", "page": 38}, {"id": "s3", "ordinal": 3, "text": "Be flexible in conducting meetings and accept different views on decision making.", "page": 38}, {"id": "s4", "ordinal": 4, "text": "Keep your voice at a moderate or reasonable level.", "page": 38}, {"id": "s5", "ordinal": 5, "text": "Practice patience when speaking with and listening to Tribal elders and other Tribal representatives.", "page": 38}, {"id": "s6", "ordinal": 6, "text": "Give undivided attention to the person who is speaking.", "page": 38}, {"id": "s7", "ordinal": 7, "text": "Avoid rude behavior while a Tribal elder is talking.", "page": 38}, {"id": "s8", "ordinal": 8, "text": "Consider cultural norms regarding eye contact.", "page": 38}, {"id": "s9", "ordinal": 9, "text": "Avoid inappropriate laughter during discussions with Tribal elders or officials.", "page": 38}], "preconditions": [], "constraints": [], "edges": [{"type": "precedes", "from": "s1", "to": "s2"}, {"type": "precedes", "from": "s2", "to": "s3"}, {"type": "precedes", "from": "s3", "to": "s4"}, {"type": "precedes", "from": "s4", "to": "s5"}, {"type": "precedes", "from": "s5", "to": "s6"}, {"type": "precedes", "from": "s6", "to": "s7"}, {"type": "precedes", "from": "s7", "to": "s8"}, {"type": "precedes", "from": "s8", "to": "s9"}]}, "error": null, "input_tokens": 1069, "output_tokens": 518, "cached_tokens": null}, {"chunk_idx": 65, "graph": {"steps": [{"id": "s1", "ordinal": 1, "text": "Dress respectfully as for any business meeting with elected officials or distinguished representatives of a government.", "page": null}, {"id": "s2", "ordinal": 2, "text": "Consider the prior experience, involvement, education, and training of the Tribe as related to the technical or licensing matter at hand.", "page": null}, {"id": "s3", "ordinal": 3, "text": "Determine the need to provide explanations for technical and licensing terms.", "page": null}, {"id": "s4", "ordinal": 4, "text": "Respect Tribal interests, cultural diversity, customs, and agendas.", "page": null}, {"id": "s5", "ordinal": 5, "text": "Respect Tribal Council leaders as officials of another government.", "page": null}, {"id": "s6", "ordinal": 6, "text": "Listen carefully; ask questions for clarification.", "page": null}, {"id": "s7", "ordinal": 7, "text": "Consider what you say; do not promise what you may be unable to deliver.", "page": null}, {"id": "s8", "ordinal": 8, "text": "Communicate with the Tribe because it is the key to successful relationships.", "page": null}, {"id": "s9", "ordinal": 9, "text": "Familiarize yourself with the Tribe’s specific information and understand the history and current issues, concerns, and expertise of the Tribe or Tribes with whom you may work.", "page": null}], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1018, "output_tokens": 380, "cached_tokens": null}, {"chunk_idx": 68, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 926, "output_tokens": 23, "cached_tokens": null}, {"chunk_idx": 71, "graph": {"steps": [], "preconditions": [], "constraints": [], "edges": []}, "error": null, "input_tokens": 1229, "output_tokens": 23, "cached_tokens": null}]}